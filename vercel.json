{
  "version": 2,
  "rewrites": [
    { "source": "/landing/(.*)", "destination": "/landing/index.html" },
    { "source": "/landing", "destination": "/landing/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/judge", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
